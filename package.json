{
  "name": "ai-swarm-desktop",
  "version": "1.0.0",
  "description": "Free AI Swarm Desktop with OpenClaw - Uses cloud GPUs from Google, NVIDIA, Oracle, AWS and more",
  "main": "dist/main.js",
  "author": "Mathew Simpson",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build": "tsc && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.mattypattysapps.aiswarmdesktop",
    "productName": "AI Swarm Desktop",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "electron-log": "^5.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "electron-builder": "^24.6.0",
    "electron-rebuild": "^3.2.0",
    "typescript": "^5.2.0",
    "electron": "^27.0.0"
  }
}